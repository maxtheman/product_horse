FROM jrottenberg/ffmpeg:4.4-nvidia

RUN ffmpeg -encoders | grep -q h264_nvenc || (echo "h264_nvenc codec not found" && exit 1)
# can't test ffmpeg more directly because deploy has no gpu, but if I could, heres a 1 second test you could run with no output:
# ffmpeg -f lavfi -i testsrc=duration=5:size=1920x1080:rate=30 -c:v h264_nvenc -preset fast -b:v 5M -f null -

WORKDIR /app


# build-essential and gcc are  for building python packages
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
    curl \
    libpq-dev \
    libcairo2-dev \
    imagemagick \
    pkg-config \
    python3 \
    python3-pip \
    build-essential \
    gcc \
    python3-dev \
    fonts-freefont-otf \
    ghostscript \
    && apt-get install -f \
    && apt-get autoremove -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install dotenvx
RUN curl -sfS https://dotenvx.sh/install.sh | sh

# Modify ImageMagick policy
RUN sed -i 's/rights="none" pattern="@\*"/rights="read|write" pattern="@*"/' /etc/ImageMagick-6/policy.xml

# Force dpkg to configure packages
RUN dpkg --configure -a

# Copy the dist files into the image
COPY gpu_app/product_horse-0.1.0-py3-none-any.whl ./
COPY gpu_app/product_horse-0.1.0.tar.gz ./
COPY ../storage_client /app/storage_client

# Assert that storage_client is not empty
RUN if [ -z "$(ls -A /app/storage_client)" ]; then \
    echo "Error: storage_client directory is empty" && exit 1; \
fi

# Install the wheel file and the local dependency
RUN pip3 install --no-cache-dir --upgrade pip && \
    pip3 install --no-cache-dir product_horse-0.1.0-py3-none-any.whl && \
    pip3 install --no-cache-dir /app/storage_client

# Remove the copied dist files to keep the image clean
RUN rm product_horse-0.1.0-py3-none-any.whl product_horse-0.1.0.tar.gz

# Copy environment file
COPY ../.env.production .

# Expose the port FastAPI will run on
EXPOSE 8000

ENTRYPOINT []

# Command to run the FastAPI application
CMD ["dotenvx", "run", "-f", ".env.production", "--", "uvicorn", "--host", "0.0.0.0", "--port", "8000", "--workers", "3", "product_horse.run_modal:app"]